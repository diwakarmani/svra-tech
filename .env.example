# SVRA Tech – Environment Variables
# Copy this file to .env.local and fill in values before running locally.

# API endpoint for the enquiry/contact form (default is the SVRA TMS public endpoint)
NEXT_PUBLIC_ENQUIRY_API_URL=https://svra-tms-native-latest.onrender.com/api/public/enquiry

# Entity code sent with every enquiry submission (do not change unless directed)
NEXT_PUBLIC_ENTITY_CODE=SVRA-TECH
